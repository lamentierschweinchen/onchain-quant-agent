{
    "api": {
        "baseUrl": "https://api.multiversx.com",
        "gatewayUrl": "https://gateway.multiversx.com",
        "timeout": 30000,
        "rateLimitDelay": 200
    },
    "monitoring": {
        "pollIntervalMs": 6000,
        "maxQueueSize": 10000
    },
