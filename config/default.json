        "schedule": "0 9 * * 0",
        "retentionDays": 90
    },
    "notifications": {
        "slack": {
            "enabled": false,
            "webhookUrl": ""
        },
        "email": {
            "enabled": false,
            "from": "",
            "to": []
        }
    }
}